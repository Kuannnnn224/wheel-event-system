PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=wheel_app
DB_PASSWORD=wheel_password
DB_DATABASE=wheel_event
TYPEORM_SYNC=true

# Optional IANA timezone, e.g. America/New_York or Asia/Tokyo.
# Leave empty to use the server/runtime local timezone.
BUSINESS_TIME_ZONE=

JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=8h
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Optional. Leave empty in local dev so demo links follow the admin page origin.
WEBVIEW_BASE_URL=
# Webview calls this base path after reading /demo/client-config.
# Local Vite dev proxies /api to the backend.
WEBVIEW_API_BASE_URL=/api
DEMO_TOKEN_TTL_MINUTES=30
PROBABILITY_CONFIG_PATH=config/probability.json
PROBABILITY_IMPORT_STORAGE_PATH=../storage/probability-imports
