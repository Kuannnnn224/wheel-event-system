{
  "name": "wheel-event-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "db": "docker compose -p wheel-event up -d",
    "start": "npm --prefix backend-node8 start",
    "check": "npm --prefix backend-node8 run check",
    "check-db": "npm --prefix backend-node8 run check:db",
    "smoke:offline": "npm --prefix backend-node8 run smoke:offline",
    "smoke:http": "npm --prefix backend-node8 run smoke:http",
    "verify": "npm run check && npm run smoke:offline && npm run check-db && npm run smoke:http"
  }
}
