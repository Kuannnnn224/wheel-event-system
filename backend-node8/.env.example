PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://kuannnnn224.github.io

DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=wheel_app
DB_PASSWORD=wheel_password
DB_DATABASE=wheel_event
DB_CONNECTION_LIMIT=10

# Optional IANA timezone, e.g. Asia/Taipei. Leave empty to use server local timezone.
BUSINESS_TIME_ZONE=

JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=8h
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Local same-origin default. If WEBVIEW_BASE_URL points to GitHub Pages/CDN, use an absolute public API URL.
WEBVIEW_BASE_URL=
WEBVIEW_API_BASE_URL=/api
# GitHub Pages/CDN example:
# WEBVIEW_BASE_URL=https://kuannnnn224.github.io/wheel-event-system/webview.html
# WEBVIEW_API_BASE_URL=https://your-public-api-domain.example/api
WEBVIEW_SESSION_TTL_MINUTES=30
PROBABILITY_CONFIG_PATH=config/probability.json
PROBABILITY_IMPORT_STORAGE_PATH=storage/probability-imports
PUBLIC_PATH=public
